---
import type { Lang } from '../data/i18n';
import { t, WA_GENERAL } from '../data/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const base = lang === 'es' ? '' : '/en';
const quickLinks = [
  { href: `${base}/tours/cataratas-niagara/`,         label: lang === 'es' ? 'Cataratas del Niágara'  : 'Niagara Falls'         },
  { href: `${base}/tours/nueva-york-completa/`,       label: lang === 'es' ? 'Nueva York Completa'    : 'New York Complete'     },
  { href: `${base}/tours/nueva-york-vip/`,            label: 'New York VIP'                                                     },
  { href: `${base}/tours/atlantic-city-philadelphia/`,label: 'Atlantic City & Philadelphia'                                     },
  { href: `${base}/tours/washington-dc/`,             label: 'Washington D.C.'                                                  },
  { href: `${base}/tours/templo-hindu-new-jersey/`,   label: lang === 'es' ? 'Templo Hindú & NJ'      : 'Hindu Temple & NJ'    },
  { href: `${base}/tours/cavernas-nueva-york/`,       label: lang === 'es' ? 'Cavernas de NY'          : 'NY Caverns'           },
  { href: `${base}/tours/parques-familiares/`,       label: lang === 'es' ? 'Parques Familiares'      : 'Family Parks'         },
];
---

<footer id="contacto" class="bg-navy text-white border-t border-white/5">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-14">

      <!-- Brand -->
      <div class="space-y-5">
        <a href={lang === 'es' ? '/' : '/en/'} class="flex items-center gap-3 group">
          <div class="bg-white rounded-2xl p-1.5 shadow-md flex-shrink-0">
            <img
              src="/logo.jpeg"
              alt="JL Tours Inc"
              class="h-12 w-auto object-contain rounded-xl"
              width="50"
              height="50"
              loading="lazy"
            />
          </div>
          <div>
            <span class="block text-white font-black text-lg leading-tight group-hover:text-amber transition-colors">JL Tours Inc</span>
            <span class="block text-amber text-xs font-medium tracking-wide">{lang === 'es' ? 'Tours desde Boston' : 'Tours from Boston'}</span>
          </div>
        </a>

        <p class="text-white/70 text-sm leading-relaxed max-w-xs">
          {t(lang, 'footer.tagline')}
        </p>

        <div class="flex items-center gap-2 text-white/70 text-sm">
          <svg class="w-3.5 h-3.5 text-amber/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <span>{t(lang, 'footer.ceo')}</span>
        </div>

        <!-- DOT legitimacy badge -->
        <div class="inline-flex items-center gap-2.5 bg-amber/10 border border-amber/30 rounded-2xl px-4 py-2.5" data-reveal>
          <svg class="w-5 h-5 text-amber flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/>
            <polyline points="9 11.5 11 13.5 15 9.5"/>
          </svg>
          <div class="leading-tight">
            <p class="text-[0.62rem] font-semibold text-amber/80 uppercase tracking-wider">{t(lang, 'about.dot.label')}</p>
            <p class="text-white font-display font-bold text-sm">#3866673</p>
          </div>
        </div>

        <!-- About link -->
        <a href={`${base}/sobre-nosotros/`} class="inline-flex items-center gap-1.5 text-amber hover:text-white text-sm font-semibold transition-colors w-fit">
          {t(lang, 'nav.about')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>

        <!-- Social icons -->
        <div class="flex items-center gap-2 pt-1">
          <a href="https://www.instagram.com/jltoursboston" target="_blank" rel="noopener noreferrer" aria-label="Instagram @jltoursboston"
            class="w-9 h-9 rounded-full bg-white/8 hover:bg-amber text-white/60 hover:text-navy flex items-center justify-center transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/jltoursboston" target="_blank" rel="noopener noreferrer" aria-label="Facebook JL Tours Boston"
            class="w-9 h-9 rounded-full bg-white/8 hover:bg-amber text-white/60 hover:text-navy flex items-center justify-center transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.tiktok.com/@jltoursboston" target="_blank" rel="noopener noreferrer" aria-label="TikTok @jltoursboston"
            class="w-9 h-9 rounded-full bg-white/8 hover:bg-amber text-white/60 hover:text-navy flex items-center justify-center transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
            </svg>
          </a>
          <a href="https://wa.me/18573899523" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp +1 857-389-9523"
            class="w-9 h-9 rounded-full bg-white/8 hover:bg-whatsapp text-white/60 hover:text-white flex items-center justify-center transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.524 5.847L.057 23.49a.5.5 0 0 0 .609.61l5.71-1.494A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.852 0-3.587-.504-5.073-1.383l-.364-.217-3.77.987.998-3.686-.237-.381A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-xs font-bold tracking-widest uppercase text-amber mb-5">
          {lang === 'es' ? 'Nuestros Tours' : 'Our Tours'}
        </h3>
        <ul class="space-y-2.5">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="flex items-center gap-2.5 text-white/70 hover:text-white text-sm transition-colors group">
                <span class="w-1.5 h-1.5 rounded-full bg-amber/40 group-hover:bg-amber transition-colors flex-shrink-0"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-bold tracking-widest uppercase text-amber mb-5">
          {t(lang, 'footer.contact')}
        </h3>
        <div class="space-y-4">

          <!-- Location -->
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-white/8 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-white/80 text-sm font-medium">East Boston, MA 02128</p>
              <p class="text-white/70 text-xs mt-0.5">
                {lang === 'es' ? 'Salida: Walgreens East Boston' : 'Departure: Walgreens East Boston'}
              </p>
            </div>
          </div>

          <!-- Phone -->
          <a href="tel:+18573899523" class="flex items-center gap-3 group">
            <div class="w-8 h-8 rounded-lg bg-white/8 group-hover:bg-white/15 flex items-center justify-center flex-shrink-0 transition-colors">
              <svg class="w-4 h-4 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <span class="text-white/70 group-hover:text-white text-sm transition-colors">+1 857-389-9523</span>
          </a>

          <!-- WhatsApp CTA -->
          <a
            href={WA_GENERAL[lang]}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 inline-flex items-center justify-center gap-2.5 w-full px-5 py-3 bg-whatsapp hover:bg-whatsapp-dark text-white font-semibold text-sm rounded-xl transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.524 5.847L.057 23.49a.5.5 0 0 0 .609.61l5.71-1.494A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.852 0-3.587-.504-5.073-1.383l-.364-.217-3.77.987.998-3.686-.237-.381A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            {lang === 'es' ? 'Escríbenos por WhatsApp' : 'Message us on WhatsApp'}
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-white/70 text-xs">
        <p>{t(lang, 'footer.rights')}</p>
        <address
          class="not-italic"
          itemscope
          itemtype="https://schema.org/TravelAgency"
        >
          <span itemprop="name" class="sr-only">JL Tours Boston</span>
          <span itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
            <span itemprop="addressLocality">East Boston</span>,&nbsp;<span itemprop="addressRegion">MA</span>&nbsp;<span itemprop="postalCode">02128</span>
          </span>
          &nbsp;·&nbsp;
          <a href="tel:+18573899523" itemprop="telephone" class="hover:text-amber transition-colors">+1 857-389-9523</a>
        </address>
      </div>
    </div>
  </div>

</footer>
