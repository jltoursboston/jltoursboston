---
import type { Lang } from '../../data/i18n';
import { t } from '../../data/i18n';
import Icon from '../ui/Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const es = lang === 'es';

const pillars = [
  { icon: 'compass' as const, titleKey: 'about.mission.title', textKey: 'about.mission.text' },
  { icon: 'sparkle' as const, titleKey: 'about.vision.title',  textKey: 'about.vision.text'  },
  { icon: 'heart' as const,   titleKey: 'about.value.title',   textKey: 'about.value.text'   },
];
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14 max-w-3xl mx-auto" data-reveal>
      <p class="text-sky-text font-semibold text-sm tracking-widest uppercase mb-3">{t(lang, 'about.eyebrow')}</p>
      <h1 class="font-display font-bold text-4xl lg:text-5xl text-navy mb-4 leading-tight text-balance">
        {t(lang, 'about.title')}
      </h1>
      <p class="text-navy/70 text-lg leading-relaxed">{t(lang, 'about.subtitle')}</p>
    </div>

    <!-- Misión · Visión · Propuesta de Valor -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 mb-16">
      {pillars.map((p, i) => (
        <div
          class="group bg-cream rounded-3xl p-7 lg:p-8 border border-navy/5 hover:border-amber/40 hover:-translate-y-1 transition-all duration-300 flex flex-col"
          data-reveal
          style={`--rd: ${i * 90}ms`}
        >
          <span class="inline-grid place-items-center w-14 h-14 rounded-2xl bg-sky/10 text-sky-text mb-5 group-hover:bg-amber/15 group-hover:text-amber-text transition-colors">
            <Icon name={p.icon} class="w-7 h-7" />
          </span>
          <h2 class="font-display font-bold text-xl text-navy mb-3">{t(lang, p.titleKey)}</h2>
          <p class="text-navy/70 text-sm leading-relaxed">{t(lang, p.textKey)}</p>
        </div>
      ))}
    </div>

    <!-- Nuestra Esencia -->
    <div class="relative overflow-hidden rounded-[1.75rem] bg-gradient-to-br from-navy via-navy to-[#0b1c30] p-9 sm:p-12 text-center text-white mb-10" data-reveal>
      <div class="absolute -top-16 -left-10 w-56 h-56 rounded-full bg-sky/10 blur-2xl" aria-hidden="true"></div>
      <div class="absolute -bottom-16 -right-10 w-64 h-64 rounded-full bg-amber/10 blur-2xl" aria-hidden="true"></div>
      <div class="relative max-w-3xl mx-auto">
        <p class="inline-flex items-center gap-2 text-amber text-xs font-semibold uppercase tracking-[0.18em] mb-4">
          <Icon name="star" class="w-4 h-4" />
          {t(lang, 'about.essence.title')}
        </p>
        <p class="font-display font-bold text-2xl sm:text-3xl leading-snug mb-5 text-balance">
          {t(lang, 'about.essence.text')}
        </p>
        <p class="text-amber font-display font-black text-xl sm:text-2xl">{t(lang, 'about.essence.kicker')}</p>
        <p class="text-white/55 text-sm mt-1 tracking-wide">JL TOURS — {t(lang, 'footer.tagline')}</p>
      </div>
    </div>

    <!-- Franja de confianza: DOT · 32+ años · Reconocimiento -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6">
      <!-- DOT destacado -->
      <div class="md:col-span-1 flex items-center gap-4 bg-amber/10 border-2 border-amber/40 rounded-2xl p-5" data-reveal>
        <span class="flex-shrink-0 inline-grid place-items-center w-12 h-12 rounded-xl bg-amber/20 text-amber-text">
          <Icon name="shield" class="w-6 h-6" />
        </span>
        <div class="min-w-0">
          <p class="text-[0.68rem] font-semibold text-amber-text/80 uppercase tracking-wider">{t(lang, 'about.dot.label')}</p>
          <p class="font-display font-black text-2xl text-navy leading-none">#{t(lang, 'about.dot.number')}</p>
        </div>
      </div>

      <!-- 32+ años -->
      <div class="flex items-center gap-4 bg-cream border border-navy/5 rounded-2xl p-5" data-reveal style="--rd: 70ms">
        <span class="flex-shrink-0 inline-grid place-items-center w-12 h-12 rounded-xl bg-sky/10 text-sky-text">
          <Icon name="calendar" class="w-6 h-6" />
        </span>
        <div class="min-w-0">
          <p class="text-[0.68rem] font-semibold text-navy/55 uppercase tracking-wider">{es ? 'Experiencia' : 'Experience'}</p>
          <p class="font-display font-black text-2xl text-navy leading-none">32+</p>
        </div>
      </div>

      <!-- Reconocimiento -->
      <div class="flex items-center gap-4 bg-cream border border-navy/5 rounded-2xl p-5" data-reveal style="--rd: 140ms">
        <span class="flex-shrink-0 inline-grid place-items-center w-12 h-12 rounded-xl bg-sky/10 text-sky-text">
          <Icon name="check" class="w-6 h-6" />
        </span>
        <p class="text-navy/75 text-sm leading-snug">{t(lang, 'about.dot.note')}</p>
      </div>
    </div>

    <!-- Datos de la empresa (ficha legible para personas, Google y asistentes de IA) -->
    <div class="mt-16 max-w-3xl mx-auto" data-reveal>
      <div class="text-center mb-6">
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-navy mb-2">{t(lang, 'about.data.title')}</h2>
        <p class="text-navy/60 text-sm">{t(lang, 'about.data.intro')}</p>
      </div>
      <div class="overflow-hidden rounded-2xl border border-navy/10">
        <table class="w-full text-sm">
          <caption class="sr-only">{t(lang, 'about.data.title')} — JL Tours Boston</caption>
          <tbody class="divide-y divide-navy/8">
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3 w-2/5">{es ? 'Nombre legal' : 'Legal name'}</th>
              <td class="px-4 py-3 text-navy">JL Tours Inc</td>
            </tr>
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3">{t(lang, 'about.dot.label')}</th>
              <td class="px-4 py-3 text-navy">US DOT #{t(lang, 'about.dot.number')}</td>
            </tr>
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3">{es ? 'Fundación' : 'Founded'}</th>
              <td class="px-4 py-3 text-navy">1994 · {es ? '32+ años de experiencia' : '32+ years of experience'}</td>
            </tr>
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3">{es ? 'Dirección' : 'Address'}</th>
              <td class="px-4 py-3 text-navy">119 London St, East Boston, MA 02128, USA</td>
            </tr>
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3">{es ? 'Teléfono / WhatsApp' : 'Phone / WhatsApp'}</th>
              <td class="px-4 py-3 text-navy">
                <a href="tel:+18573899523" class="hover:text-sky-text transition-colors">+1 857-389-9523</a>
              </td>
            </tr>
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3">{es ? 'Horario de atención' : 'Business hours'}</th>
              <td class="px-4 py-3 text-navy">{es ? 'Lunes a domingo, 9:00 – 19:00' : 'Monday–Sunday, 9 AM – 7 PM'}</td>
            </tr>
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3">{es ? 'Idiomas' : 'Languages'}</th>
              <td class="px-4 py-3 text-navy">Español · English</td>
            </tr>
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3">{es ? 'Zonas que servimos' : 'Areas served'}</th>
              <td class="px-4 py-3 text-navy">{es ? 'East Boston, Chelsea, Revere, Lynn, Everett y el Gran Boston' : 'East Boston, Chelsea, Revere, Lynn, Everett & Greater Boston'}</td>
            </tr>
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3">{es ? 'Rango de precios' : 'Price range'}</th>
              <td class="px-4 py-3 text-navy">$190 – $430 USD {es ? '(+ cotización según el tour)' : '(+ quote depending on the tour)'}</td>
            </tr>
            <tr class="odd:bg-cream/60">
              <th scope="row" class="text-left font-semibold text-navy/70 align-top px-4 py-3">{es ? 'Redes sociales' : 'Social media'}</th>
              <td class="px-4 py-3 text-navy">Instagram · Facebook · TikTok · @jltoursboston</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</section>
