---
import { Image } from 'astro:assets';
import type { Lang } from '../../data/i18n';
import { tourImg } from '../../utils/images';
import { t } from '../../data/i18n';
import { familyParks } from '../../data/tours';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const parks = lang === 'es' ? familyParks.parks : familyParks.parksEn;
const waLink = familyParks.whatsappMessage[lang];
---

<section class="py-20 lg:py-28 bg-navy text-white overflow-hidden relative">
  <!-- Decorative background pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-10 left-10 w-72 h-72 rounded-full bg-sky"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 rounded-full bg-amber"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Text content -->
      <div data-reveal>
        <p class="text-amber font-semibold text-sm tracking-widest uppercase mb-3">{t(lang, 'family.eyebrow')}</p>
        <h2 class="font-display font-bold text-4xl lg:text-5xl mb-6 leading-tight text-balance">
          {t(lang, 'family.title')}
        </h2>
        <p class="text-white/75 text-lg leading-relaxed mb-8">
          {t(lang, 'family.subtitle')}
        </p>

        <!-- Parks list -->
        <ul class="space-y-3 mb-10">
          {parks.map(park => (
            <li class="flex items-center gap-3 text-white/85">
              <span class="w-7 h-7 rounded-full bg-amber/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              {park}
            </li>
          ))}
        </ul>

        <!-- Transport badge -->
        <div class="inline-flex items-center gap-2 bg-white/10 rounded-full px-4 py-2 text-sm text-white/80 mb-8">
          <svg class="w-4 h-4 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
          </svg>
          {t(lang, 'family.transport')}
        </div>

        <!-- CTA -->
        <div>
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-8 py-4 bg-whatsapp hover:bg-whatsapp-dark text-white font-bold text-lg rounded-2xl transition-colors shadow-lg"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.524 5.847L.057 23.49a.5.5 0 0 0 .609.61l5.71-1.494A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.852 0-3.587-.504-5.073-1.383l-.364-.217-3.77.987.998-3.686-.237-.381A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            {t(lang, 'family.cta')}
          </a>
        </div>
      </div>

      <!-- Image grid -->
      <div class="grid grid-cols-2 gap-3" data-reveal>
        <div class="group overflow-hidden rounded-2xl h-44">
          <Image
            src={tourImg('parks-sixflags.jpg')}
            alt={lang === 'es' ? 'Six Flags New England — montañas rusas' : 'Six Flags New England — roller coasters'}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            loading="lazy"
            widths={[300, 480]}
            sizes="(min-width: 1024px) 280px, 45vw"
            format="webp"
          />
        </div>
        <div class="group overflow-hidden rounded-2xl h-44 mt-6">
          <Image
            src={tourImg('parks-agua.jpg')}
            alt={lang === 'es' ? 'Parque acuático — diversión en el agua' : 'Water park — aquatic fun'}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            loading="lazy"
            widths={[300, 480]}
            sizes="(min-width: 1024px) 280px, 45vw"
            format="webp"
          />
        </div>
        <div class="group overflow-hidden rounded-2xl h-44">
          <Image
            src={tourImg('parks-zoo.jpg')}
            alt={lang === 'es' ? 'Parque acuático — toboganes' : 'Water park — slides'}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            loading="lazy"
            widths={[300, 480]}
            sizes="(min-width: 1024px) 280px, 45vw"
            format="webp"
          />
        </div>
        <div class="group overflow-hidden rounded-2xl h-44 mt-6">
          <Image
            src={tourImg('parks-familia.jpg')}
            alt={lang === 'es' ? 'Familia disfrutando un parque' : 'Family enjoying a theme park'}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            loading="lazy"
            widths={[300, 480]}
            sizes="(min-width: 1024px) 280px, 45vw"
            format="webp"
          />
        </div>
      </div>
    </div>
  </div>
</section>
