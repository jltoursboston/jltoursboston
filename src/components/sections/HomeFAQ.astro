---
import type { Lang } from '../../data/i18n';
import { t } from '../../data/i18n';
import Icon from '../ui/Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const faqs = [
  { q: t(lang, 'homefaq.q1'), a: t(lang, 'homefaq.a1') },
  { q: t(lang, 'homefaq.q2'), a: t(lang, 'homefaq.a2') },
  { q: t(lang, 'homefaq.q3'), a: t(lang, 'homefaq.a3') },
  { q: t(lang, 'homefaq.q4'), a: t(lang, 'homefaq.a4') },
  { q: t(lang, 'homefaq.q5'), a: t(lang, 'homefaq.a5') },
];
---

<section class="py-20 lg:py-28 bg-cream" id="faq">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-12" data-reveal>
      <p class="text-sky-text font-semibold text-sm tracking-widest uppercase mb-3">FAQ</p>
      <h2 class="font-display font-bold text-4xl lg:text-5xl text-navy mb-4 text-balance">{t(lang, 'homefaq.title')}</h2>
      <p class="text-navy/75 text-lg">{t(lang, 'homefaq.subtitle')}</p>
    </div>

    <!-- Accordion -->
    <div class="space-y-3" id="home-faq-list">
      {faqs.map((item, i) => (
        <div
          class="home-faq-item bg-white border border-navy/10 rounded-2xl overflow-hidden shadow-sm transition-colors hover:border-navy/20"
          itemscope
          itemtype="https://schema.org/Question"
          data-reveal
          style={`--rd: ${i * 55}ms`}
        >
          <button
            type="button"
            class="home-faq-trigger w-full flex items-center justify-between gap-4 px-5 sm:px-6 py-5 text-left focus-visible:outline focus-visible:outline-2 focus-visible:outline-sky"
            aria-expanded="false"
            data-idx={i}
          >
            <span class="font-semibold text-navy" itemprop="name">{item.q}</span>
            <span class="home-faq-arrow flex-shrink-0 text-navy/40 transition-transform duration-300">
              <Icon name="chevron-down" class="w-5 h-5" />
            </span>
          </button>
          <div
            class="home-faq-answer-wrap"
            itemscope
            itemtype="https://schema.org/Answer"
            itemprop="acceptedAnswer"
          >
            <div class="overflow-hidden">
              <p class="px-5 sm:px-6 pb-5 pt-1 text-navy/70 text-sm leading-relaxed" itemprop="text">{item.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .home-faq-answer-wrap { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.32s ease; }
  .home-faq-item.open .home-faq-answer-wrap { grid-template-rows: 1fr; }
  .home-faq-item.open .home-faq-arrow { transform: rotate(180deg); }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.home-faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.home-faq-item');
      if (!item) return;
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.home-faq-item.open').forEach(el => {
        el.classList.remove('open');
        el.querySelector('.home-faq-trigger')?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
