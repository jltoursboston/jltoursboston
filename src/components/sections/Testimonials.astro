---
import type { Lang } from '../../data/i18n';
import { t } from '../../data/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const testimonials = [
  {
    es: {
      name: 'María G.',
      location: 'East Boston, MA',
      text: 'El tour a Niágara fue increíble. Alex es un guía excepcional, siempre pendiente de todos. El hotel quedaba a literalmente una cuadra de las cataratas. ¡Ya estamos planeando el próximo viaje con JL Tours!',
      tour: 'Cataratas del Niágara',
    },
    en: {
      name: 'María G.',
      location: 'East Boston, MA',
      text: 'The Niagara tour was incredible. Alex is an exceptional guide, always attentive to everyone. The hotel was literally one block from the falls. We\'re already planning our next trip with JL Tours!',
      tour: 'Niagara Falls',
    },
  },
  {
    es: {
      name: 'Carlos R.',
      location: 'Chelsea, MA',
      text: 'Fui con mi familia a Nueva York y la experiencia fue de 10. Ver la Estatua de la Libertad en el ferry, Times Square, todo en un solo día. El precio es muy justo por todo lo que incluye. 100% recomendado.',
      tour: 'Nueva York – Experiencia Completa',
    },
    en: {
      name: 'Carlos R.',
      location: 'Chelsea, MA',
      text: 'I went with my family to New York and the experience was a 10/10. Seeing the Statue of Liberty from the ferry, Times Square, all in one day. The price is very fair for everything included. 100% recommended.',
      tour: 'New York – Complete Experience',
    },
  },
  {
    es: {
      name: 'Ana & Luis M.',
      location: 'Revere, MA',
      text: 'Washington D.C. nos dejó sin palabras. Dos días perfectos, hoteles cómodos y Alex siempre explicando la historia de cada lugar. Los museos del Smithsonian son gratuitos y alucinantes. ¡Volvemos el año que viene!',
      tour: 'Washington D.C.',
    },
    en: {
      name: 'Ana & Luis M.',
      location: 'Revere, MA',
      text: 'Washington D.C. left us speechless. Two perfect days, comfortable hotels and Alex always explaining the history of each place. The Smithsonian museums are free and amazing. We\'re coming back next year!',
      tour: 'Washington D.C.',
    },
  },
];
---

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'JL Tours Boston — Reseñas de clientes',
  itemListElement: testimonials.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Review',
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      author: { '@type': 'Person', name: item.es.name },
      itemReviewed: { '@type': 'TravelAgency', name: 'JL Tours Boston', url: 'https://jltoursboston.com' },
      reviewBody: item.es.text,
    },
  })),
})} />

<section class="py-20 lg:py-28 bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14" data-reveal>
      <p class="text-amber font-semibold text-sm tracking-widest uppercase mb-3">
        {lang === 'es' ? 'Reseñas' : 'Reviews'}
      </p>
      <h2 class="font-display font-bold text-4xl lg:text-5xl mb-4">{t(lang, 'testimonials.title')}</h2>
      <p class="text-white/65 text-lg max-w-xl mx-auto">{t(lang, 'testimonials.subtitle')}</p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((item, i) => {
        const content = item[lang];
        return (
          <article class="bg-white/8 rounded-2xl p-7 border border-white/10 hover:border-amber/30 transition-colors"
                   data-reveal style={`--rd: ${i * 100}ms`}>
            <!-- Stars -->
            <div class="flex gap-1 mb-4" aria-label={lang === 'es' ? '5 estrellas' : '5 stars'}>
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-amber" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="text-white/80 leading-relaxed mb-6 italic">
              "{content.text}"
            </blockquote>

            <!-- Author -->
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-amber/20 flex items-center justify-center flex-shrink-0">
                <span class="text-amber font-display font-bold text-lg">{content.name[0]}</span>
              </div>
              <div>
                <p class="font-semibold text-white">{content.name}</p>
                <p class="text-white/50 text-sm">{content.location}</p>
              </div>
            </div>

            <!-- Tour tag -->
            <div class="mt-4 pt-4 border-t border-white/10">
              <span class="text-xs text-sky font-medium">
                ✓ {lang === 'es' ? 'Viajó en:' : 'Traveled on:'} {content.tour}
              </span>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
