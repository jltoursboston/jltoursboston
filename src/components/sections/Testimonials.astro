---
import type { Lang } from '../../data/i18n';
import { t, GOOGLE_BUSINESS, formatMonth } from '../../data/i18n';
import { testimonials, googleRating } from '../../data/testimonials';
import GoogleG from '../GoogleG.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const starLabel = (n: number) => lang === 'es' ? `${n} de 5 estrellas` : `${n} out of 5 stars`;
const reviewCountLabel = t(lang, 'testimonials.reviewCountLabel').replace('{n}', String(googleRating.reviewCount));
const aggFullStars = Math.round(googleRating.rating);
---

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'JL Tours Boston — Reseñas de clientes',
  itemListElement: testimonials.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Review',
      reviewRating: { '@type': 'Rating', ratingValue: String(item.rating), bestRating: '5', worstRating: '1' },
      author: { '@type': 'Person', name: item.name },
      itemReviewed: { '@type': 'TravelAgency', name: 'JL Tours Boston', url: 'https://jltoursboston.com' },
      reviewBody: item.text,
      datePublished: item.date,
    },
  })),
})} />

<section class="py-20 lg:py-28 bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-10" data-reveal>
      <p class="text-amber font-semibold text-sm tracking-widest uppercase mb-3">
        {lang === 'es' ? 'Reseñas' : 'Reviews'}
      </p>
      <h2 class="font-display font-bold text-4xl lg:text-5xl mb-4">{t(lang, 'testimonials.title')}</h2>
      <p class="text-white/65 text-lg max-w-xl mx-auto">{t(lang, 'testimonials.subtitle')}</p>
    </div>

    <!-- Aggregate de Google -->
    <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-3 mb-14" data-reveal>
      <div class="inline-flex items-center gap-2.5 bg-white/10 rounded-full pl-3 pr-5 py-2 border border-white/15">
        <GoogleG class="w-5 h-5 flex-shrink-0" />
        <span class="font-bold text-lg text-white">{googleRating.rating.toFixed(1)}</span>
        <span class="flex gap-0.5" role="img" aria-label={starLabel(aggFullStars)}>
          {Array.from({ length: 5 }).map((_, i) => (
            <svg class={`w-4 h-4 ${i < aggFullStars ? 'text-amber' : 'text-white/25'}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </span>
        <span class="text-white/70 text-sm">· {reviewCountLabel}</span>
      </div>
      <a href={GOOGLE_BUSINESS} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-[#8AC2F8] hover:text-amber transition-colors">
        {t(lang, 'testimonials.seeAll')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((item, i) => (
        <article class="bg-white/8 rounded-2xl p-7 border border-white/10 hover:border-amber/30 transition-colors" data-reveal style={`--rd: ${i * 100}ms`}>
          <!-- Stars -->
          <div class="flex gap-1 mb-4" role="img" aria-label={starLabel(item.rating)}>
            {Array.from({ length: 5 }).map((_, si) => (
              <svg class={`w-5 h-5 ${si < item.rating ? 'text-amber' : 'text-white/20'}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-white/80 leading-relaxed mb-6 italic">
            "{item.text}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-amber/20 flex items-center justify-center flex-shrink-0">
              <span class="text-amber font-display font-bold text-lg">{item.name.charAt(0).toUpperCase()}</span>
            </div>
            <div>
              <p class="font-semibold text-white">{item.name}</p>
              <p class="text-white/70 text-sm">{formatMonth(item.date, lang)}</p>
            </div>
          </div>

          <!-- Verified badge -->
          <div class="mt-4 pt-4 border-t border-white/10">
            <a href={GOOGLE_BUSINESS} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs text-[#8AC2F8] font-medium hover:text-amber transition-colors">
              <GoogleG class="w-3.5 h-3.5 flex-shrink-0" />
              {t(lang, 'testimonials.verified')}
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA: dejar una reseña en Google (impulsa reseñas reales) -->
    <div class="text-center mt-12" data-reveal>
      <a
        href={GOOGLE_BUSINESS}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-6 py-3.5 bg-white text-navy hover:bg-amber font-semibold rounded-full shadow-lg transition-colors"
      >
        <GoogleG class="w-5 h-5 flex-shrink-0" />
        {t(lang, 'testimonials.reviewCta')}
      </a>
    </div>
  </div>
</section>
