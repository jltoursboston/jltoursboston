---
import type { Lang } from '../../data/i18n';
import { t, GOOGLE_BUSINESS } from '../../data/i18n';
import { testimonials } from '../../data/testimonials';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'JL Tours Boston — Reseñas de clientes',
  itemListElement: testimonials.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Review',
      reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      author: { '@type': 'Person', name: item[lang].name },
      itemReviewed: { '@type': 'TravelAgency', name: 'JL Tours Boston', url: 'https://jltoursboston.com' },
      reviewBody: item[lang].text,
    },
  })),
})} />

<section class="py-20 lg:py-28 bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14" data-reveal>
      <p class="text-amber font-semibold text-sm tracking-widest uppercase mb-3">
        {lang === 'es' ? 'Reseñas' : 'Reviews'}
      </p>
      <h2 class="font-display font-bold text-4xl lg:text-5xl mb-4">{t(lang, 'testimonials.title')}</h2>
      <p class="text-white/65 text-lg max-w-xl mx-auto">{t(lang, 'testimonials.subtitle')}</p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((item, i) => {
        const content = item[lang];
        return (
          <article class="bg-white/8 rounded-2xl p-7 border border-white/10 hover:border-amber/30 transition-colors"
                   data-reveal style={`--rd: ${i * 100}ms`}>
            <!-- Stars -->
            <div class="flex gap-1 mb-4" role="img" aria-label={lang === 'es' ? '5 estrellas' : '5 stars'}>
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-amber" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="text-white/80 leading-relaxed mb-6 italic">
              "{content.text}"
            </blockquote>

            <!-- Author -->
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-amber/20 flex items-center justify-center flex-shrink-0">
                <span class="text-amber font-display font-bold text-lg">{content.name[0]}</span>
              </div>
              <div>
                <p class="font-semibold text-white">{content.name}</p>
                <p class="text-white/70 text-sm">{content.location}</p>
              </div>
            </div>

            <!-- Tour tag -->
            <div class="mt-4 pt-4 border-t border-white/10">
              <span class="text-xs text-[#8AC2F8] font-medium">
                ✓ {lang === 'es' ? 'Viajó en:' : 'Traveled on:'} {content.tour}
              </span>
            </div>
          </article>
        );
      })}
    </div>

    <!-- CTA: dejar una reseña en Google (impulsa reseñas reales) -->
    <div class="text-center mt-12" data-reveal>
      <a
        href={GOOGLE_BUSINESS}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-6 py-3.5 bg-white text-navy hover:bg-amber font-semibold rounded-full shadow-lg transition-colors"
      >
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 48 48" aria-hidden="true">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        </svg>
        {t(lang, 'testimonials.reviewCta')}
      </a>
    </div>
  </div>
</section>
