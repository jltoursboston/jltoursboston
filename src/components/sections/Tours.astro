---
import type { Lang } from '../../data/i18n';
import { t } from '../../data/i18n';
import { tours } from '../../data/tours';
import { styledAmpersand } from '../../utils/text';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<section id="tours" class="py-20 lg:py-28 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14" data-reveal>
      <p class="text-sky font-semibold text-sm tracking-widest uppercase mb-3">{t(lang, 'tours.eyebrow')}</p>
      <h2 class="font-display font-bold text-4xl lg:text-5xl text-navy mb-4">{t(lang, 'tours.title')}</h2>
      <p class="text-navy/70 text-lg max-w-2xl mx-auto">{t(lang, 'tours.subtitle')}</p>
    </div>

    <!-- Tour cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {tours.map((tour, i) => {
        const content = tour[lang];
        const tourUrl = lang === 'es' ? `/tours/${tour.slug}` : `/en/tours/${tour.slug}`;
        return (
          <a
            href={tourUrl}
            class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl block"
            style={`--rd: ${i * 80}ms`}
            data-reveal
            data-tilt
            aria-label={`${content.name} — ${content.price}`}
          >
            <!-- Card image -->
            <div class="relative h-52 overflow-hidden">
              <img
                src={tour.image}
                alt={tour.imageAlt[lang]}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                width="400"
                height="208"
              />
              <!-- Duration badge -->
              <span class="absolute top-3 right-3 bg-navy/90 backdrop-blur-sm text-white text-xs font-semibold px-2.5 py-1 rounded-full">
                {content.duration}
              </span>
              {content.capacity && (
                <span class="absolute top-3 left-3 bg-amber text-navy text-xs font-bold px-2.5 py-1 rounded-full">
                  {content.capacity}
                </span>
              )}
              {tour.nextDates.length === 0 && (
                <span class="absolute bottom-3 left-3 bg-navy/80 text-white/80 text-xs px-2.5 py-1 rounded-full">
                  {lang === 'es' ? 'Consultar fechas' : 'Ask for dates'}
                </span>
              )}
            </div>

            <!-- Card content -->
            <div class="p-5">
              <p class="text-sky text-xs font-semibold tracking-wider uppercase mb-1">{content.tagline}</p>
              <h3 class="font-display font-bold text-xl text-navy mb-3 group-hover:text-sky transition-colors" set:html={styledAmpersand(content.name)} />
              <p class="text-navy/65 text-sm leading-relaxed line-clamp-2 mb-4">{content.description}</p>

              <!-- Price + CTA -->
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-xs text-navy/50 uppercase tracking-wide">{t(lang, 'tours.card.from')}</p>
                  <p class="font-display font-bold text-2xl text-amber">{content.price}</p>
                </div>
                <span class="px-4 py-2.5 bg-navy group-hover:bg-sky text-white text-sm font-semibold rounded-xl transition-colors">
                  {t(lang, 'tours.card.cta')}
                </span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
