---
import type { Lang } from '../../data/i18n';
import { t } from '../../data/i18n';
import { tours } from '../../data/tours';
import CalendarWidget from '../ui/CalendarWidget.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<section id="calendario" class="py-20 lg:py-28 bg-cream">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-12">
      <p class="text-sky-text font-semibold text-sm tracking-widest uppercase mb-3">
        {lang === 'es' ? 'Reserva tu lugar' : 'Reserve your spot'}
      </p>
      <h2 class="font-display font-bold text-4xl lg:text-5xl text-navy mb-4">{t(lang, 'calendar.title')}</h2>
      <p class="text-navy/70 text-lg max-w-xl mx-auto">{t(lang, 'calendar.subtitle')}</p>
    </div>

    <!-- Calendar card -->
    <div class="bg-white rounded-2xl shadow-md p-6 sm:p-8">
      <CalendarWidget lang={lang} tours={tours} />
    </div>

  </div>
</section>
