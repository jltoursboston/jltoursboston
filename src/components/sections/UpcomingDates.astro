---
import type { Lang } from '../../data/i18n';
import { t } from '../../data/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// TODO: update these dates and availability before each departure
const upcomingDates = [
  {
    tourName: { es: 'Cataratas del Niágara', en: 'Niagara Falls' },
    date: { es: 'Por confirmar', en: 'To be confirmed' },
    price: '$410',
    spotsLeft: null,
    waMessage: { es: 'Hola, quiero reservar el tour a Niágara. ¿Cuál es la próxima fecha disponible?', en: 'Hello, I want to book the Niagara tour. What is the next available date?' },
  },
  {
    tourName: { es: 'Nueva York – Experiencia Completa', en: 'New York – Complete Experience' },
    date: { es: 'Por confirmar', en: 'To be confirmed' },
    price: '$270',
    spotsLeft: null,
    waMessage: { es: 'Hola, quiero reservar el tour a Nueva York Completo. ¿Cuál es la próxima fecha?', en: 'Hello, I want to book the New York Complete tour. What is the next date?' },
  },
  {
    tourName: { es: 'Washington D.C.', en: 'Washington D.C.' },
    date: { es: 'Por confirmar', en: 'To be confirmed' },
    price: '$430',
    spotsLeft: null,
    waMessage: { es: 'Hola, quiero reservar el tour a Washington D.C. ¿Cuál es la próxima fecha?', en: 'Hello, I want to book the Washington D.C. tour. What is the next date?' },
  },
  {
    tourName: { es: 'Atlantic City & Philadelphia', en: 'Atlantic City & Philadelphia' },
    date: { es: 'Por confirmar', en: 'To be confirmed' },
    price: '$420',
    spotsLeft: null,
    waMessage: { es: 'Hola, quiero reservar el tour a Atlantic City & Philadelphia. ¿Cuál es la próxima fecha?', en: 'Hello, I want to book the Atlantic City & Philadelphia tour. What is the next date?' },
  },
];
---

<section id="proximas-salidas" class="py-20 lg:py-28 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-sky font-semibold text-sm tracking-widest uppercase mb-3">
        {lang === 'es' ? 'Agenda' : 'Calendar'}
      </p>
      <h2 class="font-display font-bold text-4xl lg:text-5xl text-navy mb-4">{t(lang, 'dates.title')}</h2>
      <p class="text-navy/65 text-lg max-w-xl mx-auto">{t(lang, 'dates.subtitle')}</p>
    </div>

    <!-- Dates table -->
    <div class="bg-white rounded-2xl shadow-md overflow-hidden">
      <div class="hidden md:grid grid-cols-4 bg-navy text-white text-sm font-semibold uppercase tracking-wider">
        <div class="px-6 py-4">{lang === 'es' ? 'Tour' : 'Tour'}</div>
        <div class="px-6 py-4">{lang === 'es' ? 'Fecha de salida' : 'Departure date'}</div>
        <div class="px-6 py-4">{lang === 'es' ? 'Precio' : 'Price'}</div>
        <div class="px-6 py-4">{lang === 'es' ? 'Reservar' : 'Book'}</div>
      </div>

      <div class="divide-y divide-gray-100">
        {upcomingDates.map((item) => {
          const waLink = 'https://wa.me/18573899523?text=' + encodeURIComponent(item.waMessage[lang]);
          return (
            <div class="grid grid-cols-1 md:grid-cols-4 gap-2 md:gap-0 px-6 py-5 hover:bg-cream transition-colors">
              <div class="font-semibold text-navy">{item.tourName[lang]}</div>
              <div class="text-navy/70 md:px-2">
                <span class="md:hidden font-medium text-navy/50 text-xs uppercase mr-2">{lang === 'es' ? 'Fecha:' : 'Date:'}</span>
                <span class="inline-flex items-center gap-1.5">
                  <svg class="w-4 h-4 text-sky flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  {item.date[lang]}
                </span>
              </div>
              <div class="font-display font-bold text-amber text-xl md:px-2">
                {item.price} <span class="text-sm font-sans font-normal text-navy/50">/persona</span>
              </div>
              <div>
                <a
                  href={waLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2 bg-whatsapp hover:bg-whatsapp-dark text-white text-sm font-semibold rounded-xl transition-colors"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.524 5.847L.057 23.49a.5.5 0 0 0 .609.61l5.71-1.494A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.852 0-3.587-.504-5.073-1.383l-.364-.217-3.77.987.998-3.686-.237-.381A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
                  </svg>
                  {t(lang, 'dates.whatsapp')}
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <p class="text-center text-navy/50 text-sm mt-6">
      {lang === 'es'
        ? 'Las fechas se confirman vía WhatsApp. Escríbenos para conocer la próxima salida disponible.'
        : 'Dates are confirmed via WhatsApp. Message us to find the next available departure.'}
    </p>
  </div>
</section>
