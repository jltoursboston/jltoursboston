---
import type { Lang } from '../../data/i18n';
import { t } from '../../data/i18n';
import Icon from '../ui/Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const cards = [
  { icon: 'bus', titleKey: 'whyus.1.title', descKey: 'whyus.1.desc' },
  { icon: 'globe', titleKey: 'whyus.2.title', descKey: 'whyus.2.desc' },
  { icon: 'coffee', titleKey: 'whyus.3.title', descKey: 'whyus.3.desc' },
  { icon: 'camera', titleKey: 'whyus.4.title', descKey: 'whyus.4.desc' },
  { icon: 'calendar', titleKey: 'whyus.5.title', descKey: 'whyus.5.desc' },
  { icon: 'shield', titleKey: 'whyus.6.title', descKey: 'whyus.6.desc' },
] as const;
---

<section class="py-20 lg:py-28 bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14" data-reveal>
      <p class="text-amber font-semibold text-sm tracking-widest uppercase mb-3">{t(lang, 'whyus.eyebrow')}</p>
      <h2 class="font-display font-bold text-4xl lg:text-5xl mb-4 text-balance">{t(lang, 'whyus.title')}</h2>
      <p class="text-white/70 text-lg max-w-2xl mx-auto">{t(lang, 'whyus.subtitle')}</p>
    </div>

    <!-- 6-card grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map((card, i) => (
        <div class="group bg-white/[0.07] border border-white/10 rounded-2xl p-6 hover:border-amber/40 hover:bg-white/[0.11] hover:-translate-y-1 transition-all duration-300"
             data-reveal style={`--rd: ${i * 70}ms`}>
          <span class="inline-grid place-items-center w-12 h-12 rounded-xl bg-amber/15 text-amber mb-4 group-hover:bg-amber/25 transition-colors">
            <Icon name={card.icon} class="w-6 h-6" />
          </span>
          <h3 class="font-display font-bold text-lg text-white mb-2">{t(lang, card.titleKey)}</h3>
          <p class="text-white/65 text-sm leading-relaxed">{t(lang, card.descKey)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
