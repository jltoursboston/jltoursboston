---
import type { Lang } from '../../data/i18n';
import { t } from '../../data/i18n';
import type { Tour } from '../../data/tours';

interface Props {
  lang: Lang;
  tours: Tour[];
  singleTour?: boolean;
}
const { lang, tours: tourList, singleTour = false } = Astro.props;

// Build a map of date → tour(s) for JS (solo fechas futuras: reduce el HTML inline)
const todayISO = new Date().toISOString().slice(0, 10);
const dateMap: Record<string, { name: string; wa: string; slug: string }[]> = {};
for (const tour of tourList) {
  for (const date of tour.nextDates) {
    if (date < todayISO) continue;
    if (!dateMap[date]) dateMap[date] = [];
    dateMap[date].push({
      name: tour[lang].name,
      wa: tour.whatsappMessage[lang],
      slug: tour.slug,
    });
  }
}

const dayNames = lang === 'es'
  ? ['Do', 'Lu', 'Ma', 'Mi', 'Ju', 'Vi', 'Sa']
  : ['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'];

const monthNames = lang === 'es'
  ? ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre']
  : ['January','February','March','April','May','June','July','August','September','October','November','December'];
---

<div class="calendar-widget" id="cal-widget">
  <!-- Month navigation -->
  <div class="flex items-center justify-between mb-6">
    <button
      id="cal-prev"
      type="button"
      class="p-2 rounded-xl hover:bg-navy/10 transition-colors text-navy"
      aria-label={t(lang, 'calendar.prev')}
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>
    <h3 id="cal-month-label" class="font-display font-bold text-xl text-navy"></h3>
    <button
      id="cal-next"
      type="button"
      class="p-2 rounded-xl hover:bg-navy/10 transition-colors text-navy"
      aria-label={t(lang, 'calendar.next')}
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
  </div>

  <!-- Day headers -->
  <div class="grid grid-cols-7 mb-2">
    {dayNames.map(d => (
      <div class="text-center text-xs font-semibold text-navy/70 uppercase py-2">{d}</div>
    ))}
  </div>

  <!-- Calendar grid -->
  <div id="cal-grid" class="grid grid-cols-7 gap-1"></div>

  <!-- Legend -->
  <div class="flex items-center gap-4 mt-4 text-sm text-navy/75">
    <span class="flex items-center gap-1.5">
      <span class="w-3 h-3 rounded-full bg-sky-text inline-block"></span>
      {t(lang, 'calendar.available')}
    </span>
  </div>

  <!-- Tour popup -->
  <div
    id="cal-popup"
    class="hidden mt-4 bg-white border border-navy/10 rounded-2xl p-5 shadow-lg"
    aria-live="polite"
  >
    <p class="text-xs text-navy/70 uppercase font-semibold mb-2" id="cal-popup-date"></p>
    <div id="cal-popup-tours" class="space-y-3"></div>
  </div>
</div>

<script define:vars={{ dateMap, monthNames, singleTour, bookLabel: t(lang, 'calendar.book'), lang }}>
  const grid = document.getElementById('cal-grid');
  const label = document.getElementById('cal-month-label');
  const popup = document.getElementById('cal-popup');
  const popupDate = document.getElementById('cal-popup-date');
  const popupTours = document.getElementById('cal-popup-tours');

  const today = new Date();
  let year = today.getFullYear();
  let month = today.getMonth();

  if (singleTour) {
    const isoDates = Object.keys(dateMap).sort();
    const hasCurrentMonth = isoDates.some((d) => {
      const [y, m] = d.split('-').map(Number);
      return y === year && (m - 1) === month;
    });
    if (!hasCurrentMonth && isoDates.length > 0) {
      const [y, m] = isoDates[0].split('-').map(Number);
      year = y;
      month = m - 1;
    }
  }

  function isoDate(y, m, d) {
    return `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
  }

  function render() {
    label.textContent = `${monthNames[month]} ${year}`;
    grid.innerHTML = '';

    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    // Empty cells before first day
    for (let i = 0; i < firstDay; i++) {
      grid.insertAdjacentHTML('beforeend', '<div></div>');
    }

    for (let d = 1; d <= daysInMonth; d++) {
      const iso = isoDate(year, month, d);
      const tours = dateMap[iso];
      const isPast = new Date(year, month, d) < new Date(today.getFullYear(), today.getMonth(), today.getDate());

      const btn = document.createElement(tours ? 'button' : 'div');
      btn.className = [
        'text-center py-2 rounded-xl text-sm font-medium transition-all',
        isPast ? 'text-navy/25' : 'text-navy',
        tours && !isPast ? 'bg-sky-text text-white font-bold cursor-pointer hover:scale-105 hover:shadow-md' : '',
        !tours && !isPast ? 'hover:bg-navy/5' : '',
      ].join(' ');
      btn.textContent = String(d);

      if (tours && !isPast) {
        btn.setAttribute('type', 'button');
        btn.setAttribute('data-iso', iso);
        btn.addEventListener('click', () => showPopup(iso, tours));
      }

      grid.appendChild(btn);
    }
  }

  function showPopup(iso, tours) {
    const [y, m, d] = iso.split('-');
    const dateObj = new Date(Number(y), Number(m) - 1, Number(d));
    popupDate.textContent = dateObj.toLocaleDateString(lang === 'es' ? 'es-US' : 'en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

    popupTours.innerHTML = tours.map(t => `
      <div class="flex items-center justify-between gap-3 p-3 bg-cream rounded-xl">
        <span class="font-semibold text-navy text-sm">${t.name}</span>
        <a
          href="${t.wa}"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-whatsapp hover:bg-whatsapp-dark text-white text-xs font-bold rounded-lg transition-colors flex-shrink-0"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.524 5.847L.057 23.49a.5.5 0 0 0 .609.61l5.71-1.494A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.852 0-3.587-.504-5.073-1.383l-.364-.217-3.77.987.998-3.686-.237-.381A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          ${bookLabel}
        </a>
      </div>
    `).join('');

    popup.classList.remove('hidden');
  }

  document.getElementById('cal-prev')?.addEventListener('click', () => {
    month--;
    if (month < 0) { month = 11; year--; }
    popup.classList.add('hidden');
    render();
  });

  document.getElementById('cal-next')?.addEventListener('click', () => {
    month++;
    if (month > 11) { month = 0; year++; }
    popup.classList.add('hidden');
    render();
  });

  // Escape cierra el popup de fechas
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !popup.classList.contains('hidden')) {
      popup.classList.add('hidden');
    }
  });

  render();
</script>
