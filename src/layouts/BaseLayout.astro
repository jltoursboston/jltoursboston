---
import '../styles/global.css';
import type { Lang } from '../data/i18n';
import { t } from '../data/i18n';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  hreflangEs?: string;
  hreflangEn?: string;
}

const {
  lang,
  title = t(lang, 'seo.title'),
  description = t(lang, 'seo.description'),
  ogImage = 'https://jltoursboston.com/logo.jpeg',
  canonicalURL = Astro.url.href,
  hreflangEs,
  hreflangEn,
} = Astro.props;

const canonicalHref = lang === 'es'
  ? `https://jltoursboston.com/`
  : `https://jltoursboston.com/en/`;

const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : `https://jltoursboston.com${ogImage}`;

// LocalBusiness + TravelAgency schema (SEO local — East Boston)
const gaId = import.meta.env.PUBLIC_GA_ID as string | undefined;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'TravelAgency'],
  name: 'JL Tours Boston',
  description: 'JL Tours Boston offers bilingual guided tours (Spanish & English) departing from East Boston to top destinations: Niagara Falls, New York City, Washington DC, Atlantic City, Philadelphia, Hindu Temple NJ, and more. Family-friendly trips with comfortable transportation and experienced guides. Easy booking via WhatsApp — no complicated reservations. Serving the Latino community of Greater Boston. Call or text: 857-389-9523.',
  url: 'https://jltoursboston.com',
  telephone: '+18573899523',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'East Boston',
    addressRegion: 'MA',
    postalCode: '02128',
    addressCountry: 'US',
  },
  openingHours: ['Mo-Su 09:00-19:00'],
  areaServed: ['Boston, MA', 'East Boston, MA', 'Massachusetts, US'],
  sameAs: [
    'https://www.instagram.com/jltoursboston',
    'https://www.facebook.com/jltoursboston',
    'https://www.tiktok.com/@jltoursboston',
  ],
  founder: {
    '@type': 'Person',
    name: 'Alex López',
  },
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Font preconnect (Core Web Vitals) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL ?? canonicalHref} />

    <!-- Hreflang — dinámico para páginas de tour, fallback al homepage -->
    <link rel="alternate" hreflang="es" href={hreflangEs ?? 'https://jltoursboston.com/'} />
    <link rel="alternate" hreflang="en" href={hreflangEn ?? 'https://jltoursboston.com/en/'} />
    <link rel="alternate" hreflang="x-default" href="https://jltoursboston.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL ?? canonicalHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:locale" content={lang === 'es' ? 'es_US' : 'en_US'} />
    <meta property="og:site_name" content="JL Tours Boston" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Favicon & manifest -->
    <link rel="icon" type="image/jpeg" href="/logo.jpeg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#10243E" />

    <!-- LocalBusiness + TravelAgency schema (SEO local) -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Slot para schemas adicionales por página (TouristTrip, FAQPage, BreadcrumbList) -->
    <slot name="head-schemas" />

    <!-- Google Analytics 4 (solo si PUBLIC_GA_ID está configurado) -->
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} is:inline></script>
        <script define:vars={{ gaId }} is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class="bg-cream font-sans text-navy antialiased">
    <slot />
    {gaId && (
      <script define:vars={{ lang }} is:inline>
        document.addEventListener('click', function(e) {
          const link = e.target.closest('a[href*="wa.me"]');
          if (!link) return;
          const tour = link.dataset.waTour || 'general';
          if (typeof gtag !== 'undefined') {
            gtag('event', 'whatsapp_click', { tour: tour, language: lang });
          }
        });
      </script>
    )}
  </body>
</html>
