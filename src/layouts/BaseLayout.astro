---
import '../styles/global.css';
import type { Lang } from '../data/i18n';
import { t, GOOGLE_BUSINESS } from '../data/i18n';
import { googleRating } from '../data/testimonials';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  hreflangEs?: string;
  hreflangEn?: string;
  preloadImage?: string;
  preloadImageSrcset?: string;
  preloadImageAvif?: string;
  preloadImageAvifSrcset?: string;
  noindex?: boolean;
}

const {
  lang,
  title = t(lang, 'seo.title'),
  description = t(lang, 'seo.description'),
  ogImage = 'https://jltoursboston.com/og-home.jpg',
  canonicalURL = Astro.url.href,
  hreflangEs,
  hreflangEn,
  preloadImage,
  preloadImageSrcset,
  preloadImageAvif,
  preloadImageAvifSrcset,
  noindex = false,
} = Astro.props;

const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : `https://jltoursboston.com${ogImage}`;

// LocalBusiness + TravelAgency schema (SEO local — East Boston)
const gaId = import.meta.env.PUBLIC_GA_ID as string | undefined;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'TravelAgency'],
  name: 'JL Tours Boston',
  description: 'JL Tours Boston offers guided tours in Spanish departing from East Boston to top destinations: Niagara Falls, New York City, Washington DC, Atlantic City, Philadelphia, Hindu Temple NJ, and more. Family-friendly trips with comfortable transportation and experienced guides. Easy booking via WhatsApp — no complicated reservations. Serving the Latino community of Greater Boston. Call or text: 857-389-9523 or 617-669-0228.',
  url: 'https://jltoursboston.com',
  telephone: '+18573899523',
  contactPoint: [
    { '@type': 'ContactPoint', telephone: '+18573899523', contactType: 'reservations', areaServed: 'US', availableLanguage: ['Spanish', 'English'] },
    { '@type': 'ContactPoint', telephone: '+16176690228', contactType: 'reservations', areaServed: 'US', availableLanguage: ['Spanish', 'English'] },
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: '119 London St',
    addressLocality: 'East Boston',
    addressRegion: 'MA',
    postalCode: '02128',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 42.3702,
    longitude: -71.0389,
  },
  image: 'https://jltoursboston.com/og-home.jpg',
  logo: 'https://jltoursboston.com/logo.jpeg',
  priceRange: '$190 - $430',
  foundingDate: '1994-01-01',
  foundingLocation: { '@type': 'Place', name: 'Boston, MA' },
  slogan: t(lang, 'footer.tagline'),
  knowsLanguage: ['es', 'en'],
  identifier: [{ '@type': 'PropertyValue', name: 'USDOT', value: '3866673' }],
  openingHours: ['Mo-Su 09:00-19:00'],
  areaServed: ['Boston, MA', 'East Boston, MA', 'Lawrence, MA', 'Lowell, MA', 'Newton, MA', 'Massachusetts, US'],
  sameAs: [
    'https://www.instagram.com/jltoursboston',
    'https://www.facebook.com/jltoursboston',
    'https://www.tiktok.com/@jltoursboston',
    GOOGLE_BUSINESS,
  ],
  founder: {
    '@type': 'Person',
    name: 'Alex López',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: String(googleRating.rating),
    bestRating: '5',
    worstRating: '1',
    reviewCount: String(googleRating.reviewCount),
  },
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Font preconnect (Core Web Vitals) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Carga asíncrona de fuentes: no bloquea el primer render (display=swap muestra fallback) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600;700&display=swap" />
    </noscript>

    <!-- Preload de la imagen LCP (hero); con srcset el navegador elige la variante correcta.
         Si hay AVIF se preloadea SOLO ese (type="image/avif"): los navegadores sin soporte
         omiten el preload y cargan el WebP del <picture>, sin doble descarga. -->
    {preloadImageAvif && preloadImageAvifSrcset && (
      <link rel="preload" as="image" href={preloadImageAvif} imagesrcset={preloadImageAvifSrcset} imagesizes="100vw" type="image/avif" fetchpriority="high" />
    )}
    {!preloadImageAvifSrcset && preloadImage && preloadImageSrcset && (
      <link rel="preload" as="image" href={preloadImage} imagesrcset={preloadImageSrcset} imagesizes="100vw" fetchpriority="high" />
    )}
    {!preloadImageAvifSrcset && preloadImage && !preloadImageSrcset && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Hreflang — dinámico para páginas de tour, fallback al homepage -->
    <link rel="alternate" hreflang="es" href={hreflangEs ?? 'https://jltoursboston.com/'} />
    <link rel="alternate" hreflang="en" href={hreflangEn ?? 'https://jltoursboston.com/en/'} />
    <link rel="alternate" hreflang="x-default" href="https://jltoursboston.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'es' ? 'es_US' : 'en_US'} />
    <meta property="og:site_name" content="JL Tours Boston" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Favicon & manifest -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#10243E" />

    <!-- LocalBusiness + TravelAgency schema (SEO local) -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Slot para schemas adicionales por página (TouristTrip, FAQPage, BreadcrumbList) -->
    <slot name="head-schemas" />

    <!-- Google Analytics 4 (solo si PUBLIC_GA_ID está configurado) -->
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} is:inline></script>
        <script define:vars={{ gaId }} is:inline>
          // Astro envuelve cada <script define:vars> en su propia IIFE aislada, asi
          // que una simple "function gtag(){}" queda atrapada en ese scope y nunca
          // se expone como window.gtag para los demas scripts (listener de clics,
          // QuickQuote, etc.). Se asigna explicitamente a window para que
          // "typeof gtag !== 'undefined'" funcione en cualquier otro <script> de la pagina.
          window.dataLayer = window.dataLayer || [];
          window.gtag = function(){ window.dataLayer.push(arguments); };
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class="bg-cream font-sans text-navy antialiased">
    <slot />
    {gaId && (
      <script define:vars={{ lang }} is:inline>
        document.addEventListener('click', function(e) {
          const link = e.target.closest('a[href*="wa.me"]');
          if (!link) return;
          const tour = link.dataset.waTour || 'general';
          if (typeof gtag !== 'undefined') {
            // Los links de WhatsApp son target="_blank", asi que en desktop la pagina
            // no se descarga y el evento tiene tiempo de sobra para enviarse. En movil,
            // GA4/gtag ya usa sendBeacon/fetch keepalive por defecto, asi que el envio
            // sobrevive el cambio a la app. transport_type: 'beacon' es un remanente de
            // Universal Analytics, inofensivo pero no imprescindible; se mantiene explicito.
            gtag('event', 'whatsapp_click', { tour: tour, language: lang, transport_type: 'beacon' });
          }
        });
      </script>
    )}
    <!-- Scroll progress bar -->
    <div class="scroll-progress" aria-hidden="true">
      <div class="scroll-progress-bar" id="scroll-bar"></div>
    </div>

    <!-- Global animation system: scroll reveals + card tilt + scroll bar + magnetic -->
    <script>
      (function () {
        const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reducedMotion) {
          // Sin animaciones: revela todo y muestra los valores finales de los contadores
          document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('visible'));
          document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
            el.textContent = (el.dataset.prefix || '') + (el.dataset.count || '0') + (el.dataset.suffix || '');
          });
          return;
        }

        // ── Reveal on scroll ──
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              io.unobserve(e.target);
            }
          }),
          { threshold: 0.06, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
        setTimeout(() => {
          document.querySelectorAll('[data-reveal]:not(.visible)').forEach((el) => el.classList.add('visible'));
        }, 5000);

        // ── Count-up on scroll ──
        const countIO = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            const el = e.target as HTMLElement;
            const target = parseFloat(el.dataset.count || '0');
            const suffix = el.dataset.suffix || '';
            const prefix = el.dataset.prefix || '';
            const decimals = (String(target).split('.')[1] || '').length;
            const duration = 1600;
            const start = performance.now();
            const startVal = 0;
            const tick = (now: number) => {
              const p = Math.min((now - start) / duration, 1);
              const ease = 1 - Math.pow(1 - p, 3);
              el.textContent = prefix + (startVal + (target - startVal) * ease).toFixed(decimals) + suffix;
              if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
            countIO.unobserve(el);
          });
        }, { threshold: 0.5 });
        document.querySelectorAll('[data-count]').forEach((el) => countIO.observe(el));

        // ── Card 3D tilt (desktop only) ──
        if (!matchMedia('(hover: hover) and (pointer: fine)').matches) return;
        document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
          card.addEventListener('mousemove', (e) => {
            const r = card.getBoundingClientRect();
            const x = ((e as MouseEvent).clientX - r.left) / r.width - 0.5;
            const y = ((e as MouseEvent).clientY - r.top) / r.height - 0.5;
            card.style.transform = `perspective(900px) rotateY(${x * 8}deg) rotateX(${-y * 5}deg) translateY(-6px)`;
            card.style.boxShadow = `${-x * 8}px ${-y * 4}px 24px rgba(16,36,62,0.18)`;
            card.style.transition = 'transform 0.08s linear, box-shadow 0.08s linear';
          });
          card.addEventListener('mouseleave', () => {
            card.style.transform = '';
            card.style.boxShadow = '';
            card.style.transition = 'transform 0.5s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s ease';
          });
        });

        // ── Scroll progress bar ──
        const scrollBar = document.getElementById('scroll-bar');
        if (scrollBar) {
          const updateBar = () => {
            const max = document.documentElement.scrollHeight - window.innerHeight;
            scrollBar.style.transform = max > 0 ? `scaleX(${scrollY / max})` : 'scaleX(0)';
          };
          window.addEventListener('scroll', updateBar, { passive: true });
          updateBar();
        }

        // ── Magnetic buttons ──
        document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((el) => {
          const inner = document.createElement('span');
          inner.className = 'magnetic-inner';
          while (el.firstChild) inner.appendChild(el.firstChild);
          el.appendChild(inner);
          let mtx = 0, mty = 0, mcx = 0, mcy = 0, magRaf: number | null = null;
          el.addEventListener('mousemove', (e) => {
            const r = el.getBoundingClientRect();
            mtx = ((e.clientX - r.left) / r.width - 0.5) * 0.4 * r.width;
            mty = ((e.clientY - r.top) / r.height - 0.5) * 0.4 * r.height;
            if (!magRaf) magRaf = requestAnimationFrame(tickMag);
          });
          el.addEventListener('mouseleave', () => { mtx = 0; mty = 0; if (!magRaf) magRaf = requestAnimationFrame(tickMag); });
          function tickMag() {
            mcx += (mtx - mcx) * 0.2; mcy += (mty - mcy) * 0.2;
            inner.style.transform = `translate3d(${mcx.toFixed(1)}px,${mcy.toFixed(1)}px,0)`;
            magRaf = (Math.abs(mtx - mcx) > 0.1 || Math.abs(mty - mcy) > 0.1) ? requestAnimationFrame(tickMag) : null;
          }
        });
      })();
    </script>
  </body>
</html>
