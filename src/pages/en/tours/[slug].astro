---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import WhatsAppFloat from '../../../components/WhatsAppFloat.astro';
import TourDetail from '../../../components/tour/TourDetail.astro';
import { tours } from '../../../data/tours';
import { tourImg, heroImage, heroAvif, ogImage } from '../../../utils/images';

export async function getStaticPaths() {
  return tours.map(tour => ({
    params: { slug: tour.slug },
    props: { tour },
  }));
}

const { tour } = Astro.props;
const lang = 'en';
const content = tour[lang];

const heroImg = await heroImage(tourImg(tour.image));
const heroImgAvif = await heroAvif(tourImg(tour.image));
const ogImg = await ogImage(tourImg(tour.image));

const waBook = tour.whatsappMessage[lang];

const priceMatch = /\$(\d+)/.exec(content.price);
const priceAmount = priceMatch?.[1];

const pageUrl = `https://jltoursboston.com/en/tours/${tour.slug}/`;
const priceToken = priceMatch ? content.price.split(' ')[0] : 'Quote';
const pageTitle = `${content.name} Tour from Boston | ${priceToken} | JL Tours Boston`;

const touristTripSchema = {
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  name: `${content.name} Tour from Boston in Spanish`,
  description: content.description,
  url: pageUrl,
  image: `https://jltoursboston.com${ogImg.src}`,
  touristType: { '@type': 'Audience', audienceType: 'Spanish-speaking travelers from Boston' },
  availableLanguage: { '@type': 'Language', name: 'Spanish' },
  duration: content.duration,
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    url: waBook,
    ...(priceAmount ? { price: priceAmount, priceCurrency: 'USD' } : { description: content.price }),
  },
  provider: {
    '@type': 'TravelAgency',
    name: 'JL Tours Boston',
    telephone: '+18573899523',
    url: 'https://jltoursboston.com',
  },
  departureLocation: {
    '@type': 'Place',
    name: tour.departurePoints[0] ?? 'East Boston, MA',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Boston',
      addressRegion: 'MA',
      addressCountry: 'US',
    },
  },
};

const faqSchema = content.faq && content.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faq.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'JL Tours Boston', item: 'https://jltoursboston.com/en/' },
    { '@type': 'ListItem', position: 2, name: 'Tours', item: 'https://jltoursboston.com/en/tours/' },
    { '@type': 'ListItem', position: 3, name: content.name },
  ],
};

const schemas = [touristTripSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---

<BaseLayout
  lang={lang}
  title={pageTitle}
  description={content.description}
  ogImage={ogImg.src}
  canonicalURL={pageUrl}
  hreflangEs={`https://jltoursboston.com/tours/${tour.slug}/`}
  hreflangEn={pageUrl}
  preloadImage={heroImg.src}
  preloadImageSrcset={heroImg.srcSet.attribute}
  preloadImageAvif={heroImgAvif.src}
  preloadImageAvifSrcset={heroImgAvif.srcSet.attribute}
>
  <script slot="head-schemas" type="application/ld+json" set:html={JSON.stringify(schemas)} />

  <Header lang={lang} />
  <TourDetail lang={lang} tour={tour} content={content} heroImg={heroImg} heroImgAvif={heroImgAvif} waBook={waBook} />
  <Footer lang={lang} />
  <WhatsAppFloat lang={lang} />
</BaseLayout>
