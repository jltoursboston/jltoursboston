---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Hero from '../components/sections/Hero.astro';
import Tours from '../components/sections/Tours.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import About from '../components/sections/About.astro';
import UpcomingDates from '../components/sections/UpcomingDates.astro';
import Gallery from '../components/sections/Gallery.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import HomeFAQ from '../components/sections/HomeFAQ.astro';
import QuickQuote from '../components/sections/QuickQuote.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Marquee from '../components/ui/Marquee.astro';
import Stats from '../components/sections/Stats.astro';
import { t } from '../data/i18n';
import { tourImg, heroImage } from '../utils/images';

const lang = 'es' as const;

const heroLcp = await heroImage(tourImg('niagara.jpg'));

const faqPairs: Array<[keyof typeof import('../data/i18n').ui.es, keyof typeof import('../data/i18n').ui.es]> = [
  ['homefaq.q1', 'homefaq.a1'],
  ['homefaq.q2', 'homefaq.a2'],
  ['homefaq.q3', 'homefaq.a3'],
  ['homefaq.q4', 'homefaq.a4'],
  ['homefaq.q5', 'homefaq.a5'],
];

const homeFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqPairs.map(([qKey, aKey]) => ({
    '@type': 'Question',
    name: t(lang, qKey),
    acceptedAnswer: { '@type': 'Answer', text: t(lang, aKey) },
  })),
};
---

<BaseLayout
  lang={lang}
  preloadImage={heroLcp.src}
  preloadImageSrcset={heroLcp.srcSet.attribute}
>
  <script slot="head-schemas" type="application/ld+json" set:html={JSON.stringify(homeFaqSchema)} />
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Marquee items={['Cataratas del Niágara', 'Nueva York', 'Washington D.C.', 'Atlantic City', 'Philadelphia', 'New Jersey', 'Cavernas de Howe', 'Templo Hindú NJ']} />
    <Tours lang={lang} />
    <QuickQuote lang={lang} />
    <WhyUs lang={lang} />
    <About lang={lang} />
    <Stats lang={lang} />
    <UpcomingDates lang={lang} />
    <Gallery lang={lang} />
    <Testimonials lang={lang} />
    <HomeFAQ lang={lang} />
    <FinalCTA lang={lang} />
  </main>
  <Footer lang={lang} />
  <WhatsAppFloat lang={lang} />
</BaseLayout>
