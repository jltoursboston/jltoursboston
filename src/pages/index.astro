---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Hero from '../components/sections/Hero.astro';
import Tours from '../components/sections/Tours.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import FamilyParks from '../components/sections/FamilyParks.astro';
import UpcomingDates from '../components/sections/UpcomingDates.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
---

<BaseLayout lang="es">
