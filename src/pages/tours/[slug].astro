---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import TourDetail from '../../components/tour/TourDetail.astro';
import { tours } from '../../data/tours';
import { tourImg, heroImage, ogImage } from '../../utils/images';

export async function getStaticPaths() {
  return tours.map(tour => ({
    params: { slug: tour.slug },
    props: { tour },
  }));
}

const { tour } = Astro.props;
const lang = 'es';
const content = tour[lang];

const heroImg = await heroImage(tourImg(tour.image));
const ogImg = await ogImage(tourImg(tour.image));

const waBook = tour.whatsappMessage[lang];

// Extraer precio numérico para schema (e.g. "$410 USD/persona" → "410")
const priceAmount = /\$(\d+)/.exec(content.price)?.[1] ?? '0';

const pageUrl = `https://jltoursboston.com/tours/${tour.slug}`;
const pageTitle = `Tour ${content.name} desde Boston | ${content.price.split(' ')[0]} | JL Tours Boston`;

// TouristTrip schema
const touristTripSchema = {
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  name: `Tour ${content.name} desde Boston en Español`,
  description: content.description,
  url: pageUrl,
  image: `https://jltoursboston.com${ogImg.src}`,
  touristType: { '@type': 'Audience', 'audienceType': 'Spanish-speaking travelers from Boston' },
  availableLanguage: { '@type': 'Language', name: 'Spanish' },
  duration: content.duration,
  offers: {
    '@type': 'Offer',
    price: priceAmount,
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: waBook,
  },
  provider: {
    '@type': 'TravelAgency',
    name: 'JL Tours Boston',
    telephone: '+18573899523',
    url: 'https://jltoursboston.com',
  },
  departureLocation: {
    '@type': 'Place',
    name: tour.departurePoints[0] ?? 'East Boston, MA',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Boston',
      addressRegion: 'MA',
      addressCountry: 'US',
    },
  },
};

// FAQPage schema (rich snippets en Google)
const faqSchema = content.faq && content.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faq.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
} : null;

// BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'JL Tours Boston', item: 'https://jltoursboston.com/' },
    { '@type': 'ListItem', position: 2, name: 'Tours', item: 'https://jltoursboston.com/tours/' },
    { '@type': 'ListItem', position: 3, name: content.name },
  ],
};

const schemas = [touristTripSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---

<BaseLayout
  lang={lang}
  title={pageTitle}
  description={content.description}
  ogImage={ogImg.src}
  canonicalURL={pageUrl}
  hreflangEs={pageUrl}
  hreflangEn={`https://jltoursboston.com/en/tours/${tour.slug}`}
  preloadImage={heroImg.src}
  preloadImageSrcset={heroImg.srcSet.attribute}
>
  <!-- Schemas específicos del tour en el <head> -->
  <script slot="head-schemas" type="application/ld+json" set:html={JSON.stringify(schemas)} />

  <Header lang={lang} />
  <TourDetail lang={lang} tour={tour} content={content} heroImg={heroImg} waBook={waBook} />
  <Footer lang={lang} />
  <WhatsAppFloat lang={lang} />
</BaseLayout>
