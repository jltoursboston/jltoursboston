---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import CalendarWidget from '../../components/ui/CalendarWidget.astro';
import { tours } from '../../data/tours';
import { t } from '../../data/i18n';

export async function getStaticPaths() {
  return tours.map(tour => ({
    params: { slug: tour.slug },
    props: { tour },
  }));
}

const { tour } = Astro.props;
const lang = 'es';
const content = tour[lang];

const waBook = tour.whatsappMessage[lang];

// Extraer precio numérico para schema (e.g. "$410 USD/persona" → "410")
const priceAmount = /\$(\d+)/.exec(content.price)?.[1] ?? '0';

const pageUrl = `https://jltoursboston.com/tours/${tour.slug}`;
const pageTitle = `Tour ${content.name} desde Boston | ${content.price.split(' ')[0]} | JL Tours Boston`;

// TouristTrip schema
const touristTripSchema = {
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  name: `Tour ${content.name} desde Boston en Español`,
  description: content.description,
  url: pageUrl,
  image: tour.image,
  touristType: { '@type': 'Audience', 'audienceType': 'Spanish-speaking travelers from Boston' },
  availableLanguage: { '@type': 'Language', name: 'Spanish' },
  duration: content.duration,
  offers: {
    '@type': 'Offer',
    price: priceAmount,
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: waBook,
  },
  provider: {
    '@type': 'TravelAgency',
    name: 'JL Tours Boston',
    telephone: '+18573899523',
    url: 'https://jltoursboston.com',
  },
  departureLocation: {
    '@type': 'Place',
    name: tour.departurePoints[0] ?? 'East Boston, MA',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Boston',
      addressRegion: 'MA',
      addressCountry: 'US',
    },
  },
};

// FAQPage schema (rich snippets en Google)
const faqSchema = content.faq && content.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faq.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
} : null;

// BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'JL Tours Boston', item: 'https://jltoursboston.com/' },
    { '@type': 'ListItem', position: 2, name: 'Tours', item: 'https://jltoursboston.com/tours/' },
    { '@type': 'ListItem', position: 3, name: content.name },
  ],
};

const schemas = [touristTripSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---

<BaseLayout
  lang={lang}
  title={pageTitle}
  description={content.description}
  ogImage={tour.image}
  canonicalURL={pageUrl}
  hreflangEs={pageUrl}
  hreflangEn={`https://jltoursboston.com/en/tours/${tour.slug}`}
>
  <!-- Schemas específicos del tour en el <head> -->
  <script slot="head-schemas" type="application/ld+json" set:html={JSON.stringify(schemas)} />

  <Header lang={lang} />

  <main class="pt-16">

    <!-- Tour Hero -->
    <section class="relative h-[55vh] min-h-[380px] flex items-end overflow-hidden">
      <div class="absolute inset-0">
        <img
          src={tour.image}
          alt={tour.imageAlt[lang]}
          class="w-full h-full object-cover"
          width="1200"
          height="600"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/50 to-navy/10"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-10 w-full">
        <a href="/" class="inline-flex items-center gap-1.5 text-white/60 hover:text-white text-sm mb-4 transition-colors">
          {t(lang, 'tour.back')}
        </a>
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-amber text-sm font-semibold uppercase tracking-wider mb-2">{content.tagline}</p>
            <h1 class="font-display font-black text-3xl sm:text-4xl lg:text-5xl text-white leading-tight">
              {content.name}
            </h1>
          </div>
          <div class="text-right">
            <p class="text-white/60 text-sm">{t(lang, 'tours.card.from')}</p>
            <p class="font-display font-black text-3xl text-amber">{content.price}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Gallery -->
    {tour.gallery && tour.gallery.length > 0 && (
      <section class="bg-navy/5 py-4">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-3">
            {tour.gallery.map((img) => (
              <div class="aspect-[4/3] overflow-hidden rounded-lg">
                <img
                  src={img}
                  alt={tour.imageAlt[lang]}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  width="400"
                  height="300"
                />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Sticky book bar -->
    <div class="sticky top-16 z-40 bg-white border-b border-navy/10 shadow-sm">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3 text-sm text-navy/70 overflow-hidden">
          <span class="font-display font-bold text-navy text-base truncate">{content.name}</span>
          <span class="hidden sm:inline text-navy/30">·</span>
          <span class="hidden sm:inline font-bold text-amber">{content.price}</span>
        </div>
        <a
          href={waBook}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-whatsapp hover:bg-whatsapp-dark text-white font-bold text-sm rounded-xl transition-colors flex-shrink-0"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.524 5.847L.057 23.49a.5.5 0 0 0 .609.61l5.71-1.494A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.852 0-3.587-.504-5.073-1.383l-.364-.217-3.77.987.998-3.686-.237-.381A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          {t(lang, 'tour.book')}
        </a>
      </div>
    </div>

    <!-- Main content -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-16">

      <!-- Description + includes -->
      <div class="grid lg:grid-cols-2 gap-8 items-start">
        <div>
          <p class="text-navy/70 text-lg leading-relaxed">{content.description}</p>
          {content.priceNote && (
            <p class="mt-4 text-sm text-amber font-semibold bg-amber/10 rounded-xl px-4 py-3">
              ℹ️ {content.priceNote}
            </p>
          )}
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-cream rounded-xl p-4">
            <p class="text-xs text-navy/50 uppercase tracking-wider mb-1">{lang === 'es' ? 'Duración' : 'Duration'}</p>
            <p class="font-semibold text-navy">🕐 {content.duration}</p>
          </div>
          <div class="bg-cream rounded-xl p-4">
            <p class="text-xs text-navy/50 uppercase tracking-wider mb-1">{lang === 'es' ? 'Salida' : 'Departure'}</p>
            <p class="font-semibold text-navy">🚌 {content.departure}</p>
          </div>
          <div class="bg-cream rounded-xl p-4">
            <p class="text-xs text-navy/50 uppercase tracking-wider mb-1">{lang === 'es' ? 'Regreso' : 'Return'}</p>
            <p class="font-semibold text-navy">🏁 {content.return}</p>
          </div>
          {content.capacity && (
            <div class="bg-amber/10 rounded-xl p-4 border border-amber/20">
              <p class="text-xs text-amber uppercase tracking-wider mb-1 font-semibold">{lang === 'es' ? 'Cupos' : 'Spots'}</p>
              <p class="font-bold text-navy">{content.capacity}</p>
            </div>
          )}
        </div>
      </div>

      <!-- Lo que vivirás -->
      <div>
        <h2 class="font-display font-bold text-3xl text-navy mb-6">{t(lang, 'tour.experiences')}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {content.includes.map(item => (
            <div class="flex items-start gap-3 bg-white rounded-xl p-4 shadow-sm border border-navy/5">
              <span class="text-xl flex-shrink-0">{item.slice(0, 2)}</span>
              <span class="text-navy/80 text-sm leading-relaxed">{item.slice(2).trim()}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Calendario -->
      {tour.nextDates.length > 0 ? (
        <div>
          <h2 class="font-display font-bold text-3xl text-navy mb-6">{t(lang, 'tour.calendar')}</h2>
          <div class="bg-white rounded-2xl shadow-md p-6 sm:p-8">
            <CalendarWidget lang={lang} tours={[tour]} singleTour={true} />
          </div>
        </div>
      ) : (
        <div class="bg-amber/10 border border-amber/20 rounded-2xl p-6 text-center">
          <p class="text-2xl mb-2">📅</p>
          <p class="font-bold text-navy">{t(lang, 'tour.nodates')}</p>
          <p class="text-navy/60 text-sm mt-1">{t(lang, 'tour.nodates.sub')}</p>
          <a href={waBook} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-4 px-5 py-2.5 bg-whatsapp hover:bg-whatsapp-dark text-white font-bold text-sm rounded-xl transition-colors">
            {t(lang, 'tour.book')}
          </a>
        </div>
      )}

      <!-- Itinerario -->
      <div>
        <h2 class="font-display font-bold text-3xl text-navy mb-6">{t(lang, 'tour.itinerary')}</h2>
        <div class="relative">
          <div class="absolute left-[5.5rem] top-0 bottom-0 w-px bg-navy/10"></div>
          <div class="space-y-4">
            {content.itinerary.map((item, i) => (
              <div class="flex gap-4 items-start">
                <div class="w-20 text-right flex-shrink-0">
                  <span class="text-xs font-semibold text-navy/50 leading-tight">{item.time}</span>
                </div>
                <div class="relative flex-shrink-0 mt-1">
                  <div class={`w-3 h-3 rounded-full border-2 ${i === 0 ? 'bg-amber border-amber' : 'bg-white border-navy/30'}`}></div>
                </div>
                <p class="text-navy/80 text-sm leading-relaxed pt-0.5">{item.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Actividades opcionales -->
      {content.addons && content.addons.length > 0 && (
        <div>
          <h2 class="font-display font-bold text-3xl text-navy mb-6">{t(lang, 'tour.addons')}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {content.addons.map(addon => (
              <div class="bg-white border border-navy/10 rounded-2xl p-5 shadow-sm">
                <p class="font-semibold text-navy text-sm mb-3">{addon.name}</p>
                <div class="flex items-baseline gap-2">
                  <span class="font-display font-black text-2xl text-amber">${addon.price}</span>
                  {addon.originalPrice && (
                    <span class="text-sm text-navy/40 line-through">${addon.originalPrice}</span>
                  )}
                </div>
                <div class="flex gap-2 mt-1 text-xs">
                  <span class="text-whatsapp font-semibold">{t(lang, 'tour.discount')}</span>
                  {addon.originalPrice && <span class="text-navy/40">vs. {t(lang, 'tour.regular')}</span>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Puntos de encuentro -->
      {tour.departurePoints.length > 0 && (
        <div>
          <h2 class="font-display font-bold text-3xl text-navy mb-6">{t(lang, 'tour.departure')}</h2>
          <div class="flex flex-wrap gap-3">
            {tour.departurePoints.map(point => (
              <div class="inline-flex items-center gap-2 bg-cream border border-navy/10 rounded-xl px-4 py-3">
                <span class="text-sky">📍</span>
                <span class="font-semibold text-navy text-sm">{point}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- FAQ (marcado semánticamente para FAQPage schema) -->
      {content.faq && content.faq.length > 0 && (
        <div>
          <h2 class="font-display font-bold text-3xl text-navy mb-6">{t(lang, 'tour.faq')}</h2>
          <div class="space-y-3" id="faq-list">
            {content.faq.map((item, i) => (
              <div class="faq-item bg-white border border-navy/10 rounded-2xl overflow-hidden shadow-sm" itemscope itemtype="https://schema.org/Question">
                <button
                  type="button"
                  class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left"
                  aria-expanded="false"
                  data-faq={i}
                >
                  <span class="font-semibold text-navy" itemprop="name">{item.q}</span>
                  <svg class="faq-arrow w-5 h-5 text-navy/40 flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div class="faq-answer hidden px-6 pb-5 text-navy/70 text-sm leading-relaxed border-t border-navy/5 pt-4" itemscope itemtype="https://schema.org/Answer" itemprop="acceptedAnswer">
                  <span itemprop="text">{item.a}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Métodos de pago -->
      <div>
        <h2 class="font-display font-bold text-3xl text-navy mb-6">{t(lang, 'tour.payment')}</h2>
        <div class="bg-cream rounded-2xl p-6">
          <p class="text-navy/70 text-sm mb-5 font-medium">{t(lang, 'tour.payment.note')}</p>
          <div class="flex flex-wrap gap-3">
            <div class="flex items-center gap-2 bg-white border border-navy/10 rounded-xl px-4 py-3 shadow-sm">
              <span class="font-bold text-navy text-sm">Zelle</span>
            </div>
            <div class="flex items-center gap-2 bg-white border border-navy/10 rounded-xl px-4 py-3 shadow-sm">
              <span class="font-bold text-navy text-sm">PayPal</span>
            </div>
            <div class="flex items-center gap-2 bg-white border border-navy/10 rounded-xl px-4 py-3 shadow-sm">
              <span class="font-bold text-navy text-sm">{lang === 'es' ? 'Tarjeta' : 'Card'}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA final -->
      <div class="bg-gradient-to-br from-navy to-navy/90 rounded-3xl p-8 text-center text-white">
        <p class="font-display font-black text-3xl mb-2">{t(lang, 'tour.cta.title')}</p>
        <p class="text-white/70 mb-6">{t(lang, 'tour.cta.subtitle')}</p>
        <a
          href={waBook}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 bg-whatsapp hover:bg-whatsapp-dark text-white text-lg font-bold rounded-2xl transition-all hover:-translate-y-0.5 shadow-lg hover:shadow-xl"
        >
          <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.524 5.847L.057 23.49a.5.5 0 0 0 .609.61l5.71-1.494A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.852 0-3.587-.504-5.073-1.383l-.364-.217-3.77.987.998-3.686-.237-.381A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          {t(lang, 'tour.book')}
        </a>
      </div>

    </div>
  </main>

  <Footer lang={lang} />
  <WhatsAppFloat lang={lang} />
</BaseLayout>

<script>
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const arrow = btn.querySelector('.faq-arrow');
      const isOpen = !answer?.classList.contains('hidden');

      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-arrow').forEach(a => a.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        answer?.classList.remove('hidden');
        arrow?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
