---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import Tours from '../../components/sections/Tours.astro';
import UpcomingDates from '../../components/sections/UpcomingDates.astro';

const lang = 'es' as const;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'JL Tours Boston', item: 'https://jltoursboston.com/' },
    { '@type': 'ListItem', position: 2, name: 'Tours' },
  ],
};
---

<BaseLayout
  lang={lang}
  title="Todos los Tours desde Boston | JL Tours Boston"
  description="Catálogo completo de tours y excursiones desde East Boston en español: Cataratas del Niágara, Nueva York, Washington D.C., Atlantic City, Templo Hindú y más."
  canonicalURL="https://jltoursboston.com/tours/"
  hreflangEs="https://jltoursboston.com/tours/"
  hreflangEn="https://jltoursboston.com/en/tours/"
>
  <script slot="head-schemas" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Header lang={lang} />
  <main class="pt-16 md:pt-20">
    <h1 class="sr-only">Tours y excursiones desde Boston en español</h1>
    <Tours lang={lang} />
    <UpcomingDates lang={lang} />
  </main>
  <Footer lang={lang} />
  <WhatsAppFloat lang={lang} />
</BaseLayout>
